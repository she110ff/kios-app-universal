{
  "expo": {
    "name": "KIOS Point",
    "slug": "kios-point-user",
    "version": "0.8.0",
    "scheme": "kios-point-user",
    "orientation": "portrait",
    "icon": "./assets/icons/iosOnly/ios-1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icons/acc-icon-300.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "buildNumber": "1",
      "bundleIdentifier": "io.kiospoint.user",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/acc-icon-512.png",
        "backgroundColor": "#FFC742"
      },
      "permissions": ["android.permission.INTERNET"],
      "package": "io.kiospoint.user",
      "googleServicesFile": "./google-services.json",
      "allowBackup": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/acc-icon-200.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-localization",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b9b647fa-a9b9-458b-baa8-77078790de78"
      }
    },
    "owner": "kios9pte",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b9b647fa-a9b9-458b-baa8-77078790de78"
    }
  }
}
